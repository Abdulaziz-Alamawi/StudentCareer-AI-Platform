# PostgreSQL connection string
DATABASE_URL="postgresql://studentcareer:studentcareer@localhost:5432/studentcareer"

# JWT signing secret (CHANGE THIS in production — use a long random string)
SECRET_KEY="change-me-to-a-long-random-secret"
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM="HS256"

# CORS — JSON array of allowed origins
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# App metadata
PROJECT_NAME="StudentCareer AI Platform"
API_V1_PREFIX="/api/v1"

# AI provider: "heuristic" (default, no external calls) or "openai" (future)
AI_PROVIDER="heuristic"
# OPENAI_API_KEY=""
